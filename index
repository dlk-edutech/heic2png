<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chuyển đổi HEIC sang PNG</title>
    <script src="https://cdn.jsdelivr.net/npm/heic2any/dist/heic2any.min.js"></script>
    <style>
        body { 
            font-family: Arial, sans-serif; 
            text-align: center; 
            padding: 20px; 
            background-color: #f4f4f9;
        }
        .khung-chua { 
            max-width: 600px; 
            margin: auto; 
            background: #fff;
            border: 1px solid #ddd; 
            padding: 30px; 
            border-radius: 10px; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .nut-bam { 
            padding: 10px 20px; 
            cursor: pointer; 
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 14px;
        }
        .nut-bam:hover {
            background-color: #0056b3;
        }
        #thong-bao { 
            margin-top: 15px; 
            font-weight: bold; 
            color: #333; 
        }
        #danh-sach-ket-qua {
            margin-top: 20px;
            text-align: left;
        }
    </style>
</head>
<body>

<div class="khung-chua">
    <h2>Chuyển đổi ảnh HEIC sang PNG</h2>
    <input type="file" id="chon-tap-tin" accept=".heic, .heif" multiple>
    <div id="thong-bao"></div>
    <div id="danh-sach-ket-qua"></div>
</div>

<script>
    const chonTapTin = document.getElementById('chon-tap-tin');
    const thongBao = document.getElementById('thong-bao');
    const danhSachKetQua = document.getElementById('danh-sach-ket-qua');

    // Su dung async de co the dung await ben trong vong lap
    chonTapTin.addEventListener('change', async function(suKien) {
        const danhSachTapTin = suKien.target.files;
        
        if (danhSachTapTin.length === 0) return;

        thongBao.innerText = 'Đang xử lý... Quá trình này có thể mất một lúc tuỳ vào số lượng ảnh.';
        thongBao.style.color = '#ff9800';
        danhSachKetQua.innerHTML = ''; // Xoa ket qua cua lan chuyen doi truoc

        let soLuongThanhCong = 0;

        // Lap qua tung tep da chon
        for (let i = 0; i < danhSachTapTin.length; i++) {
            const tapTin = danhSachTapTin[i];
            
            // Tao khung hien thi cho tung anh
            const divKetQua = document.createElement('div');
            divKetQua.style.marginTop = '20px';
            divKetQua.style.paddingTop = '15px';
            divKetQua.style.borderTop = '1px solid #ddd';
            divKetQua.style.textAlign = 'center';
            
            const tenFileText = document.createElement('p');
            tenFileText.innerText = 'Đang xử lý: ' + tapTin.name;
            tenFileText.style.fontWeight = 'bold';
            
            divKetQua.appendChild(tenFileText);
            danhSachKetQua.appendChild(divKetQua);

            try {
                // Su dung thu vien heic2any de chuyen doi tung anh
                const ketQuaKetXuat = await heic2any({
                    blob: tapTin,
                    toType: "image/png",
                });
                
                const ketQuaBlob = Array.isArray(ketQuaKetXuat) ? ketQuaKetXuat[0] : ketQuaKetXuat;
                const duongDanAnh = URL.createObjectURL(ketQuaBlob);
                
                // Tao the img de hien thi
                const anh = document.createElement('img');
                anh.src = duongDanAnh;
                anh.style.maxWidth = '100%';
                anh.style.borderRadius = '5px';
                anh.style.border = '1px solid #ccc';
                anh.style.marginTop = '10px';
                
                // Tao the a de tai ve
                const theTaiVe = document.createElement('a');
                theTaiVe.href = duongDanAnh;
                // Thay doi duoi file tu heic/heif sang png
                const tenFileMoi = tapTin.name.replace(/\.[^/.]+$/, "") + ".png";
                theTaiVe.download = tenFileMoi;
                theTaiVe.style.display = 'inline-block';
                theTaiVe.style.marginTop = '10px';
                theTaiVe.style.textDecoration = 'none';
                
                // Tao nut bam ben trong the a
                const nutTaiVe = document.createElement('button');
                nutTaiVe.className = 'nut-bam';
                nutTaiVe.innerText = 'Tải ảnh ' + tenFileMoi;
                
                theTaiVe.appendChild(nutTaiVe);
                
                tenFileText.innerText = 'Thành công: ' + tapTin.name;
                tenFileText.style.color = 'green';
                
                divKetQua.appendChild(anh);
                divKetQua.appendChild(document.createElement('br'));
                divKetQua.appendChild(theTaiVe);
                
                soLuongThanhCong++;
            } catch (loi) {
                console.error(loi);
                tenFileText.innerText = 'Lỗi khi chuyển đổi: ' + tapTin.name;
                tenFileText.style.color = 'red';
            }
        }

        // Cap nhat thong bao tong the
        if (soLuongThanhCong === danhSachTapTin.length) {
            thongBao.innerText = 'Đã chuyển đổi thành công tất cả ' + soLuongThanhCong + ' ảnh!';
            thongBao.style.color = 'green';
        } else if (soLuongThanhCong > 0) {
            thongBao.innerText = 'Đã chuyển đổi xong, nhưng có một số tệp bị lỗi.';
            thongBao.style.color = '#ff9800';
        } else {
            thongBao.innerText = 'Có lỗi xảy ra, không thể chuyển đổi tệp nào.';
            thongBao.style.color = 'red';
        }
    });
</script>

</body>
</html>
